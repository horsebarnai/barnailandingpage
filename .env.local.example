# Supabase project: barnailandingpage
# Settings → API → Project URL and service_role secret key.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Resend — sends an email notification after each contact submission.
# Get the key at https://resend.com/api-keys (re_xxxx...).
# Without this, the form still saves to Supabase but no email is sent.
RESEND_API_KEY=

# Optional — override the recipient (defaults to om@horsebarn.ai).
# Note: with the unverified onboarding@resend.dev sender, Resend only allows
# delivery to the email address that owns your Resend account.
CONTACT_NOTIFY_EMAIL=

# Optional — override the sender. Defaults to Resend's sandbox sender.
# Once you verify horsebarn.ai in Resend, set this to e.g. "Barn AI <contact@horsebarn.ai>".
CONTACT_FROM_EMAIL=
